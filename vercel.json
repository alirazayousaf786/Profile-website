{
  "framework": "vite",
  "buildCommand": "npm install --legacy-peer-deps && ./node_modules/.bin/vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
