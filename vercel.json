{
  "framework": "vite",
  "outputDirectory": "dist/public",
  "packageManager": "npm",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
